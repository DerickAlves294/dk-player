{
  "name": "dk-player",
  "productName": "DK Player",
  "version": "1.3.0",
  "description": "Player de música local — sem streaming pago, ouvir junto com amigos!",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.dkplayer.app",
    "productName": "DK Player",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "DerickAlves294",
      "repo": "dk-player",
      "releaseType": "release"
    }
  }
}
